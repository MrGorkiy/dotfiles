# This file is included by, rather than replacing, ~/.gitconfig.
# Keep user.name, user.email, signing and work-specific settings in ~/.gitconfig.
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    line-numbers = true
    side-by-side = false
    features = decorations
[delta "decorations"]
    commit-decoration-style = bold yellow box ul
    file-style = bold yellow ul
    file-decoration-style = none
    hunk-header-decoration-style = cyan box ul
[merge]
    conflictstyle = zdiff3
[diff]
    colorMoved = default
[pull]
    rebase = false
[fetch]
    prune = true
