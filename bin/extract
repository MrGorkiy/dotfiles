#!/usr/bin/env bash
# Extract a common archive into the current directory; never overwrites by force.
set -euo pipefail

if (( $# != 1 )) || [[ ! -f "$1" ]]; then
  printf 'Usage: %s <archive>\n' "${0##*/}" >&2
  exit 2
fi

case "$1" in
  *.tar.bz2|*.tbz2) tar -xjf "$1" ;;
  *.tar.gz|*.tgz) tar -xzf "$1" ;;
  *.tar.xz|*.txz) tar -xJf "$1" ;;
  *.tar.zst) tar --zstd -xf "$1" ;;
  *.tar) tar -xf "$1" ;;
  *.zip) unzip "$1" ;;
  *.gz) gzip -dk "$1" ;;
  *.bz2) bzip2 -dk "$1" ;;
  *.xz) xz -dk "$1" ;;
  *) printf 'Unsupported archive format: %s\n' "$1" >&2; exit 1 ;;
esac
