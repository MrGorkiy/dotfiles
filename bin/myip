#!/usr/bin/env bash
# Print the current public IP address. This intentionally makes one HTTPS request.
set -euo pipefail

if ! command -v curl >/dev/null 2>&1; then
  printf 'curl is required.\n' >&2
  exit 1
fi

curl --fail --silent --show-error --location --max-time 10 https://api.ipify.org
printf '\n'
